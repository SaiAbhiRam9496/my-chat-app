      "package": "com.normaluse.mychatapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "e922c54b-59e1-444c-a556-c9baa7fe0cf9"
      }
